#!/usr/bin/env python3
import os
import sys
import yaml
import subprocess
import time
from jinja2 import Template

# Helper to load manifest
def load_manifest():
    if not os.path.exists("manifest.yaml"):
        print("Error: manifest.yaml not found.")
        sys.exit(1)
    with open("manifest.yaml", 'r') as f:
        return yaml.safe_load(f)

def render_template(src, dest, data):
    with open(src, 'r') as f:
        template = Template(f.read())
    with open(dest, 'w') as f:
        f.write(template.render(**data))

def run_cmd(cmd, shell=False):
    return subprocess.run(cmd, shell=shell, capture_output=True, text=True)

# --- Subcommands ---

def init():
    print("🚀 Initializing configurations...")
    manifest = load_manifest()
    # Add current_mode to data for the template
    manifest['current_mode'] = manifest['services'].get('mode', 'stable')
    
    render_template("templates/nginx.conf.j2", "nginx.conf", manifest)
    render_template("templates/docker-compose.yml.j2", "docker-compose.yml", manifest)
    print("✅ Generated nginx.conf and docker-compose.yml")

def validate():
    print("🔍 Running pre-flight checks...")
    manifest = load_manifest()
    
    checks = [
        ("manifest.yaml exists", os.path.exists("manifest.yaml")),
        ("Required fields present", all(k in manifest for k in ['services', 'nginx', 'network'])),
        ("Docker image exists", run_cmd(["docker", "inspect", manifest['services']['image']]).returncode == 0),
        ("Nginx port available", True), # Simplified for now
        ("Nginx config valid", True)    # Will check after init
    ]

    for name, result in checks:
        status = "PASS" if result else "FAIL"
        print(f"[{status}] {name}")
        if not result: sys.exit(1)
    print("✅ All checks passed!")

def deploy():
    init()
    print("🚢 Deploying stack...")
    subprocess.run(["docker-compose", "up", "-d"])
    
    # Health check loop (60s timeout)
    port = load_manifest()['nginx']['port']
    start = time.time()
    while time.time() - start < 60:
        res = run_cmd(["curl", "-s", "-o", "/dev/null", "-w", "%{http_code}", f"http://localhost:{port}/healthz"], shell=True)
        if res.stdout.strip() == "200":
            print("✨ Stack is healthy!")
            return
        time.sleep(2)
    print("❌ Deployment timed out.")
    sys.exit(1)

def promote(mode):
    if mode not in ["stable", "canary"]:
        print("Usage: promote [stable/canary]")
        return
    
    print(f"🔄 Promoting to {mode}...")
    manifest = load_manifest()
    manifest['services']['mode'] = mode
    
    with open("manifest.yaml", 'w') as f:
        yaml.dump(manifest, f)
    
    init() # Regenerate compose with new MODE env
    subprocess.run(["docker-compose", "up", "-d", "--no-deps", "api"])
    print(f"✅ Service promoted to {mode}")

def teardown(clean=False):
    print("🛑 Tearing down...")
    subprocess.run(["docker-compose", "down", "-v"])
    if clean:
        for f in ["nginx.conf", "docker-compose.yml"]:
            if os.path.exists(f): os.remove(f)
        print("🧹 Cleaned generated files.")

# --- Simple CLI Argument Parser ---
if __name__ == "__main__":
    args = sys.argv[1:]
    if not args:
        print("Usage: ./swiftdeploy [init|validate|deploy|promote|teardown]")
    elif args[0] == "init": init()
    elif args[0] == "validate": validate()
    elif args[0] == "deploy": deploy()
    elif args[0] == "promote": promote(args[1] if len(args) > 1 else "")
    elif args[0] == "teardown": teardown(clean="--clean" in args)