events {
    worker_connections 1024;
}

http {
    # Custom pipe-delimited log format for Stage 4 requirements
    log_format swift_format '$remote_addr | $time_local | $status | ${request_time}s | $request';
    access_log /var/log/nginx/access.log swift_format;

    upstream api_servers {
        # 'api' matches the service name in docker-compose
        server api:{{ services.port }};
    }

    server {
        listen {{ nginx.port }};

        location / {
            proxy_pass http://api_servers;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            
            # Timeouts as defined in your manifest
            proxy_connect_timeout {{ nginx.proxy_timeout }}s;
            proxy_send_timeout {{ nginx.proxy_timeout }}s;
            proxy_read_timeout {{ nginx.proxy_timeout }}s;
        }

        # JSON Error handling for Gateway issues
        error_page 502 503 504 = @json_error;

        location @json_error {
            default_type application/json;
            return 502 '{"error": "Gateway Error", "status": 502, "message": "The upstream API is currently unavailable."}';
        }
    }
}