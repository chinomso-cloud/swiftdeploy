version: '3.8'

services:
  api:
    image: {{ services.image }}
    container_name: swift-api
    environment:
      - MODE={{ current_mode }}
      - APP_VERSION=1.0.0
      - PORT={{ services.port }}  # Matches the os.getenv("PORT") in main.py
    user: "1000:1000"
    cap_drop:
      - ALL
    networks:
      - {{ network.name }}
    volumes:
      - api_logs:/app/logs
    healthcheck:
      # This hits the dynamic port defined in your manifest.yaml
      test: ["CMD", "curl", "-f", "http://localhost:{{ services.port }}/healthz"]
      interval: 10s
      timeout: 5s
      retries: 3
    restart: always

  nginx:
    image: {{ nginx.image }}
    container_name: swift-nginx
    ports:
      # Maps your unique host port to the Nginx container port
      - "{{ nginx.port }}:{{ nginx.port }}"
    volumes:
      - ./nginx.conf:/etc/nginx/nginx.conf:ro
      - nginx_logs:/var/log/nginx
    depends_on:
      api:
        condition: service_healthy
    networks:
      - {{ network.name }}
    restart: always

networks:
  {{ network.name }}:
    driver: {{ network.driver_type }}

volumes:
  api_logs:
  nginx_logs: